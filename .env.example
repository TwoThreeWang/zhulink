# Database Configuration
DATABASE_URL="host=localhost user=postgres password=yourpassword dbname=zhulink port=5432 sslmode=disable TimeZone=Asia/Shanghai"

# Server Configuration
PORT=32919
GIN_MODE=release  # debug, release, or test (use release in production)
SESSION_SECRET="your-secret-key-change-me"

# Site Configuration
SITE_URL="https://zhulink.vip"

# LLM Configuration
LLM_BASE_URL="https://generativelanguage.googleapis.com/v1beta/openai/"
LLM_MODEL="gemini-1.5-flash"
LLM_TOKEN="your-gemini-api-key"

# Cloudflare AI Gateway (优先使用，未配置则回退到上方 LLM 配置)
CF_GATEWAY_URL="https://gateway.ai.cloudflare.com/v1/your-account-id/your-gateway-id/compat"
CF_GATEWAY_MODEL="custom-alibaba-coding/kimi-k2.5"
CF_API_TOKEN="your-cloudflare-api-token"

# Google OAuth Configuration
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Email Smtp
SMTP_HOST=email-smtp.us-east-1.amazonaws.com
SMTP_PORT=587
SMTP_USER=AKIA...
SMTP_PASS=...
SMTP_FROM=no-reply@zhulink.vip

# RSSHub Configuration
RSSHUB_INSTANCE_URL="https://rsshub.app"

# Imgur Configuration
IMGUR_CLIENT_ID="your-imgur-client-id"

# Ollama Embedding Configuration
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="nomic-embed-text"

# IndexNow Configuration (optional)
# Get API Key: https://www.bing.com/indexnow/getstarted
INDEXNOW_API_KEY="your-indexnow-api-key"